# API Configuration
VITE_API_URL=https://api.entrancegateway.com/api/v1
VITE_API_TIMEOUT=30000

# OAuth2 Configuration (Spring Boot Backend)
VITE_OAUTH2_BACKEND_URL=https://api.entrancegateway.com

# Authentication
VITE_JWT_STORAGE_KEY=entrance_gateway_token
VITE_REFRESH_TOKEN_STORAGE_KEY=entrance_gateway_refresh_token

# Features
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_SENTRY=false
VITE_MAX_QUIZ_QUESTIONS=200

# Third-party Services
VITE_SENTRY_DSN=
VITE_GOOGLE_ANALYTICS_ID=
